# Required for WalletConnect-based wallets (the QR/deep-link mobile wallets).
# Free project id: https://cloud.walletconnect.com/
# If unset, Injected (MetaMask etc.) + Coinbase Wallet still work; WC wallets won't.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Recommended: an Alchemy API key. All frontend RPC will be routed to
# https://base-mainnet.g.alchemy.com/v2/<key>. Get one at https://alchemy.com.
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Optional: explicit full RPC URL override (takes precedence over the Alchemy
# key above). Use for a non-Alchemy provider (QuickNode, Base public node, etc.).
# NEXT_PUBLIC_BASE_RPC_URL=

# Optional: contract overrides (defaults wired to the live Base mainnet deployment).
# NEXT_PUBLIC_PENNYPOT_ADDRESS=0xdCc075040Cf5888dBa26E9871427949BAb7591ba
# NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# NEXT_PUBLIC_JACKPOT_ADDRESS=0x3bAe643002069dBCbcd62B1A4eb4C4A397d042a2

# Optional: the deployment block of PennyPot — used as the floor for SharesBought
# log queries (positions history). Set this to the contract's creation block on Base
# for faster reads. Defaults to a safe earlier block.
# NEXT_PUBLIC_PENNYPOT_DEPLOY_BLOCK=46470000

# Optional: Megapot Data API key (server-side only, do NOT prefix with NEXT_PUBLIC_).
# Used by /api/megapot/tickets to proxy api.megapot.io with the higher 60req/min
# tier. Without it, the route falls back to anonymous (10req/min). Get one at
# https://api.megapot.io.
# MEGAPOT_API_KEY=mpk_live_xxx

# ── Keeper crons (see vercel.json) ─────────────────────────────────────────────
#   /api/cron/buy-ticket     every minute  — fronts the next Megapot ticket
#   /api/cron/claim-winnings  :10 hourly    — settles winning tickets of recent
#                                             rounds so holders can withdraw
# Private key of the keeper wallet both crons sign with. SERVER-ONLY SECRET —
# never prefix with NEXT_PUBLIC_. The wallet only needs ETH on Base for gas
# (the contract reserve fronts ticket USDC; claims pull winnings into the
# contract).
# KEEPER_PK=0x...
#
# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`. Set it
# in the Vercel project and the cron endpoint rejects any unauthenticated call.
# CRON_SECRET=

# Optional server-side RPC overrides for the keeper (falls back to the
# NEXT_PUBLIC_ Alchemy / RPC values above when unset).
# BASE_RPC_URL=
# ALCHEMY_API_KEY=
